# DeepSeek API配置（主要使用）
DEEPSEEK_API_KEY=sk-0ea85ecb530c429087b0c6cba3de886a
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI API配置（备用）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# 本地模型配置（可选）
LOCAL_MODEL_ENDPOINT=http://localhost:11434  # Ollama
LOCAL_MODEL_NAME=llama3.1

# 数据库配置（docker-compose up -d 启动后可用）
DATABASE_URL=postgresql://postgres:password@localhost:5432/aischool
REDIS_URL=redis://localhost:6379

# 向量数据库配置
CHROMA_PERSIST_DIRECTORY=./chroma_db

# 应用配置
DEBUG=True
PORT=8000
LLM_PROVIDER=deepseek  # deepseek, openai, local

# 关闭crewAI遥测（国内网络会导致每次启动卡30秒）
OTEL_SDK_DISABLED=true